# Generate three different random values with at least 32 characters.
REDIS_BROKER_PASSWORD=replace-with-strong-unique-broker-secret
REDIS_CACHE_PASSWORD=replace-with-strong-unique-cache-secret
REDIS_RESULT_PASSWORD=replace-with-strong-unique-result-secret

# The application URLs are injected by docker-compose.redis-scale.yml. Define
# these explicitly only when using external/managed endpoints.
# CACHE_URL=redis://cache:PASSWORD@redis-cache:6379/0
# CELERY_BROKER_URL=redis://broker:PASSWORD@redis:6379/0
# CELERY_RESULT_BACKEND=redis://results:PASSWORD@redis-results:6379/0
