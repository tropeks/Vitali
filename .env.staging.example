# Vitali — Staging Environment Variables
# Copy to .env.staging and fill in all required values before first deploy.
# See docs/DEPLOY.md for full reference including where to get each value.

# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets
ENVIRONMENT=staging
DEBUG=False
ALLOWED_HOSTS=staging.vitali.com.br,localhost
CSRF_TRUSTED_ORIGINS=https://staging.vitali.com.br

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=vitali
POSTGRES_USER=vitali
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://vitali:change-me-strong-password@postgres:5432/vitali

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ─── GHCR Image Registry ──────────────────────────────────────────────────────
GHCR_REPO=tropeks/Vitali
IMAGE_TAG=latest

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-base64-fernet-key

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@vitali.com.br

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://staging.vitali.com.br

# ─── AI / Claude ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
FEATURE_AI_TUSS=True

# ─── WhatsApp / Evolution API ────────────────────────────────────────────────
WHATSAPP_EVOLUTION_URL=http://evolution-api:8080
WHATSAPP_EVOLUTION_API_KEY=change-me-evolution-api-key
WHATSAPP_WEBHOOK_SECRET=change-me-webhook-secret
