# Vitali — Staging Environment Variables
# Copy to .env.staging and fill in all required values before first deploy.
# See docs/DEPLOY.md for full reference including where to get each value.

# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets
ENVIRONMENT=staging
DEBUG=False
ALLOWED_HOSTS=staging.vitali.com.br,localhost
CSRF_TRUSTED_ORIGINS=https://staging.vitali.com.br
# Flip only after `backfill_tenant_memberships --dry-run --report`, explicit
# grants for every orphan, a real backfill, and the verification command below.
ENFORCE_TENANT_MEMBERSHIP=False

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=vitali
POSTGRES_USER=vitali
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://vitali:change-me-strong-password@postgres:5432/vitali

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ─── GHCR Image Registry ──────────────────────────────────────────────────────
GHCR_REPO=tropeks
IMAGE_TAG=latest

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-base64-fernet-key

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@vitali.com.br

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://staging.vitali.com.br

# Internal Basic header injected by nginx only after Vitali authorization.
# Generate from a dedicated archive account; never expose it to the browser.
ORTHANC_AUTH_HEADER=Basic Y2hhbmdlLW1lOmNoYW5nZS1tZQ==
ORTHANC_USERNAME=change-me
ORTHANC_PASSWORD=change-me
ORTHANC_WEBHOOK_SECRET=change-me-strong-webhook-secret
# Production only: bind C-STORE to a trusted LAN IP when modalities push directly.
# ORTHANC_DICOM_BIND_ADDRESS=192.0.2.10

# ─── Optional PostgreSQL PITR overlay ────────────────────────────────────────
PITR_ARCHIVE_TIMEOUT=300s
PITR_MAX_WAL_AGE_SECONDS=600
PITR_S3_SSE=AES256
# Host-only paths; do not put backup contents in the repository.
PITR_BASEBACKUP_DIR=/var/backups/vitali/pitr/base
PITR_BASEBACKUP_KEEP_LAST=5

# ─── Optional observability overlay ──────────────────────────────────────────
PROMETHEUS_RETENTION=15d
PROMETHEUS_RETENTION_SIZE=20GB
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=vitali-admin
GRAFANA_COOKIE_SECURE=false
POSTGRES_EXPORTER_PASSWORD_FILE=/etc/vitali/postgres-exporter-password
REDIS_EXPORTER_PASSWORD_FILE=/etc/vitali/redis-exporter-passwords.json
GRAFANA_ADMIN_PASSWORD_FILE=/etc/vitali/grafana-admin-password

# ─── AI / Claude ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
FEATURE_AI_TUSS=True

# ─── WhatsApp / Evolution API ────────────────────────────────────────────────
WHATSAPP_EVOLUTION_URL=http://evolution-api:8080
WHATSAPP_EVOLUTION_API_KEY=change-me-evolution-api-key
WHATSAPP_WEBHOOK_SECRET=change-me-webhook-secret
