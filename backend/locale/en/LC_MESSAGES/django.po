msgid "CNPJ deve conter 14 dígitos."
msgstr "Tax ID must contain 14 digits."

#: apps/core/serializers.py:148 apps/core/serializers.py:150
msgid "CNPJ inválido."
msgstr "Invalid tax ID."

#: apps/core/serializers.py:177
msgid "Senha deve ter no mínimo 12 caracteres."
msgstr "Password must be at least 12 characters long."

#: apps/core/serializers.py:179
msgid "Senha deve conter pelo menos uma letra maiúscula."
msgstr "Password must contain at least one uppercase letter."

#: apps/core/serializers.py:181
msgid "Senha deve conter pelo menos uma letra minúscula."
msgstr "Password must contain at least one lowercase letter."

#: apps/core/serializers.py:183
msgid "Senha deve conter pelo menos um número."
msgstr "Password must contain at least one number."

#: apps/core/serializers.py:185
msgid "Senha deve conter pelo menos um caractere especial."
msgstr "Password must contain at least one special character."

