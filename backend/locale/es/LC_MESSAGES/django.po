#: apps/core/admin.py:84
msgid "Dados pessoais"
msgstr "Datos personales"

#: apps/core/admin.py:85
msgid "Acesso"
msgstr "Acceso"

#: apps/core/admin.py:86
msgid "Datas"
msgstr "Fechas"

#: apps/core/serializers.py:133
msgid ""
"Slug deve conter apenas letras minúsculas, números e hífens (2–63 "
"caracteres, não pode começar ou terminar com hífen)."
msgstr ""
"El identificador solo puede contener letras minúsculas, números y guiones "
"(2–63 caracteres, no puede empezar ni terminar con guion)."

#: apps/core/serializers.py:138
msgid "Este slug já está em uso."
msgstr "Este identificador ya está en uso."

#: apps/core/serializers.py:146
msgid "CNPJ deve conter 14 dígitos."
msgstr "El CIF/NIF debe contener 14 dígitos."

#: apps/core/serializers.py:148 apps/core/serializers.py:150
msgid "CNPJ inválido."
msgstr "CIF/NIF no válido."

#: apps/core/serializers.py:177
msgid "Senha deve ter no mínimo 12 caracteres."
msgstr "La contraseña debe tener al menos 12 caracteres."

#: apps/core/serializers.py:179
msgid "Senha deve conter pelo menos uma letra maiúscula."
msgstr "La contraseña debe contener al menos una letra mayúscula."

#: apps/core/serializers.py:181
msgid "Senha deve conter pelo menos uma letra minúscula."
msgstr "La contraseña debe contener al menos una letra minúscula."

#: apps/core/serializers.py:183
msgid "Senha deve conter pelo menos um número."
msgstr "La contraseña debe contener al menos un número."

#: apps/core/serializers.py:185
msgid "Senha deve conter pelo menos um caractere especial."
msgstr "La contraseña debe contener al menos un carácter especial."

#: apps/core/views.py:270 apps/core/views.py:435 apps/core/views.py:526
msgid "Dados inválidos."
msgstr "Datos no válidos."

#: apps/core/views.py:288
msgid "Conta temporariamente bloqueada por excesso de tentativas."
msgstr "Cuenta bloqueada temporalmente por demasiados intentos."

#: apps/core/views.py:302 apps/core/views.py:310 apps/core/views.py:330
msgid "Credenciais inválidas."
msgstr "Credenciales no válidas."

#: apps/core/views.py:318
msgid "Conta desativada."
msgstr "Cuenta desactivada."

#: apps/core/views.py:385
msgid "refresh token obrigatório."
msgstr "token de actualización obligatorio."

#: apps/core/views.py:398
msgid "Logout realizado com sucesso."
msgstr "Sesión cerrada correctamente."

#: apps/core/views.py:445
msgid "Senha atual incorreta."
msgstr "Contraseña actual incorrecta."

#: apps/core/views.py:454
msgid "Senha alterada com sucesso."
msgstr "Contraseña cambiada correctamente."

#: apps/core/views.py:498
msgid "Unsupported language code."
msgstr "Código de idioma no admitido."

#: apps/core/views.py:542
msgid "Já existe um usuário com este e-mail."
msgstr "Ya existe un usuario con este correo electrónico."

#: apps/core/views.py:628
msgid ""
"Falha ao criar a clínica. Nenhum dado parcial foi mantido; tente novamente."
msgstr ""
"No se pudo crear la clínica. No se conservaron datos parciales; inténtelo de"
" nuevo."

#: apps/core/views.py:721
msgid "Forbidden."
msgstr "Acceso denegado."
