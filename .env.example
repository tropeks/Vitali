# ─── Vitali Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in the values before running.
# NEVER commit .env to version control.

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=vitali.settings.development
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.vitali.local

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vitali:vitali@localhost:5435/vitali

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Encryption (LGPD — CPF e dados sensíveis) ───────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=UXVhbHF1ZXIgY2hhdmUgcGFyYSBkZXNlbnZvbHZpbWVudG8=

# ─── AI — Anthropic Claude (Primary) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI — OpenAI (Fallback) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── PIX — Asaas Payment Gateway (S-055) ─────────────────────────────────────
# Create sandbox account at: https://sandbox.asaas.com
# Sandbox keys start with $aact_, production keys with $act_
ASAAS_API_KEY=$aact_...
ASAAS_WEBHOOK_TOKEN=change-me-to-random-32-char-string
ASAAS_ENVIRONMENT=sandbox
PIX_CHARGE_EXPIRY_MINUTES=30

# ─── WhatsApp — Evolution API ─────────────────────────────────────────────────
WHATSAPP_EVOLUTION_URL=http://localhost:8080
WHATSAPP_EVOLUTION_API_KEY=change-me
WHATSAPP_WEBHOOK_SECRET=change-me-to-random-32-char-string
WHATSAPP_INSTANCE_NAME=vitali
WHATSAPP_CLINIC_PHONE=+5511999999999

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxx
DEFAULT_FROM_EMAIL=noreply@vitali.com.br

# ─── Sentry (Production) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── MFA — TOTP (S-062) ──────────────────────────────────────────────────────
# Days a verified MFA session stays valid before re-challenge (default: 30)
MFA_GRACE_PERIOD_DAYS=30

# ─── Prescription PDF (S-065) ────────────────────────────────────────────────
# Redis TTL in seconds for generated prescription PDFs (default: 3600 = 1h)
PRESCRIPTION_PDF_CACHE_TTL=3600

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
