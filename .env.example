# ─── Vitali Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in the values before running.
# NEVER commit .env to version control.

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=vitali.settings.development
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.vitali.local

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vitali:vitali@localhost:5435/vitali

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Encryption (LGPD — CPF e dados sensíveis) ───────────────────────────────
# Generate a real key for local dev:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The placeholder below is a valid Fernet key (all-zero bytes) — it satisfies the
# format check so `cp .env.example .env` works out of the box for migrations + CI,
# but DO NOT use it for any persisted data you care about. Generate a real key
# before storing real PII.
FIELD_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
#
# FIELD_ENCRYPTION_KEY_FILE — runtime secret file (Docker/Podman secret mount).
# If set, the key is read from this file (e.g. /run/secrets/field_encryption_key,
# readable only by the web process) and takes PRECEDENCE over FIELD_ENCRYPTION_KEY.
# Prefer this form in production: the key is NOT an env var inherited by every
# child process or exposed via /proc/<pid>/environ. Leave unset for dev/CI.
# If the path is set but the file is missing or empty, boot fails loudly —
# the server never silently falls back to the env var.
#FIELD_ENCRYPTION_KEY_FILE=/run/secrets/field_encryption_key

# ─── Celery worker least-privilege (P3-03) ───────────────────────────────────
# VITALI_ROLE labels the process type. Set per service in docker-compose.prod.yml:
#   django/web service  → no override needed (defaults to "web")
#   celery-worker       → VITALI_ROLE=worker
#   celery-beat         → VITALI_ROLE=beat
# Never set this in the shared secrets.env — it's a per-service label, not a secret.
# (Commented: "web" is the default; copying this into secrets.env would defeat that.)
# VITALI_ROLE=web

# CELERY_DATABASE_URL — less-privileged Postgres DSN for worker/beat processes.
# Create a dedicated role: CREATE ROLE vitali_worker LOGIN PASSWORD '...';
# Grant it USAGE/SELECT/INSERT/UPDATE/DELETE across ALL tenant schemas
# (django-tenants switches search_path at runtime — the worker role must reach
# every schema). Do NOT grant superuser or DDL privileges (CREATE/DROP/ALTER).
#
# IMPORTANT: workers STILL require FIELD_ENCRYPTION_KEY — Celery tasks read and
# write encrypted EMR fields (CPF, etc.). The least-privilege boundary is the DB
# credential, NOT the crypto key. Never strip FIELD_ENCRYPTION_KEY from the
# worker secret set.
#
# In production, core.E004 (`manage.py check --deploy`) fails if a worker process
# runs without a CELERY_DATABASE_URL that is distinct from DATABASE_URL.
#CELERY_DATABASE_URL=postgres://vitali_worker:CHANGE_ME@postgres:5432/vitali

# ─── Deployment profile (P3-01) ──────────────────────────────────────────────
# Controls instance behaviour — selects the Vitali operating model.
#   pool      = shared multi-tenant instance (default). Standard SaaS: all clinics
#               share the same container and public schema.
#   dedicated = single-tenant isolated instance. Foundation for the Fase 3 Tenant
#               Operator: one container + schema per clinic, full resource isolation.
# Air-gap is explicitly out of scope — Vitali is a cloud-only product.
# In production, an unrecognised value blocks boot (core.E003 system check).
DEPLOYMENT_PROFILE=pool

# ─── AI — Anthropic Claude (Primary) ─────────────────────────────────────────
# Used for TUSS code suggestion and glosa risk scoring.
# Required when FEATURE_AI_TUSS=True.
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI — OpenAI (Whisper + fallback) ─────────────────────────────────────────
# Used for audio transcription (Whisper) when the browser Web Speech API fails
# or the user uses an unsupported browser. Required when FEATURE_AI_SCRIBE=True.
OPENAI_API_KEY=sk-...

# ─── AI — Feature Flags ───────────────────────────────────────────────────────
# Clinical AI Scribe (Sprint 15). Generates SOAP notes from consultation
# audio. Tenant admin must also sign the DPA via the UI before use.
# Requires a valid OPENAI_API_KEY. Leave False until both are configured.
FEATURE_AI_SCRIBE=False

# TUSS code suggestion via LLM. Requires a valid ANTHROPIC_API_KEY.
FEATURE_AI_TUSS=False

# Whisper (server-side) fallback when browser Web Speech API is unavailable.
# Independent of FEATURE_AI_SCRIBE on/off — when scribe is on, this controls
# whether unsupported browsers get Whisper transcription instead of a hard fail.
FEATURE_WHISPER_FALLBACK=True

# ─── PIX — Asaas Payment Gateway (S-055) ─────────────────────────────────────
# Create sandbox account at: https://sandbox.asaas.com
# Sandbox keys start with $aact_, production keys with $act_
ASAAS_API_KEY=$aact_...
ASAAS_WEBHOOK_TOKEN=change-me-to-random-32-char-string
ASAAS_ENVIRONMENT=sandbox
PIX_CHARGE_EXPIRY_MINUTES=30

# ─── WhatsApp — Evolution API ─────────────────────────────────────────────────
WHATSAPP_EVOLUTION_URL=http://localhost:8080
WHATSAPP_EVOLUTION_API_KEY=change-me
WHATSAPP_WEBHOOK_SECRET=change-me-to-random-32-char-string
WHATSAPP_INSTANCE_NAME=vitali
WHATSAPP_CLINIC_PHONE=+5511999999999

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxx
DEFAULT_FROM_EMAIL=noreply@vitali.com.br

# ─── Sentry (Production) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── OpenTelemetry (P2-03 / P2-01) ──────────────────────────────────────────
# Default OFF — no OTel package is imported unless OTEL_ENABLED=true.
# Set OTEL_EXPORTER_OTLP_ENDPOINT to ship spans to a collector (e.g. Grafana Tempo,
# Jaeger, ADOT). Leave empty to print spans to stdout (dev/debug only).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vitali-backend

# ─── MFA — TOTP (S-062 / S28-04) ─────────────────────────────────────────────
# Days a sensitive-role user (admin/medico/dentista, staff, superuser) may operate
# before they MUST have enrolled MFA, measured from account creation. Hardened
# default is 7 (do not raise without a security review). Set 0 to require MFA now.
MFA_GRACE_PERIOD_DAYS=7

# ─── Prescription PDF (S-065) ────────────────────────────────────────────────
# Redis TTL in seconds for generated prescription PDFs (default: 3600 = 1h)
PRESCRIPTION_PDF_CACHE_TTL=3600

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
