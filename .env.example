# ─── Vitali Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in the values before running.
# NEVER commit .env to version control.

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=vitali.settings.development
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.vitali.local

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vitali:vitali@localhost:5435/vitali

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Encryption (LGPD — CPF e dados sensíveis) ───────────────────────────────
# Generate a real key for local dev:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The placeholder below is a valid Fernet key (all-zero bytes) — it satisfies the
# format check so `cp .env.example .env` works out of the box for migrations + CI,
# but DO NOT use it for any persisted data you care about. Generate a real key
# before storing real PII.
FIELD_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# ─── AI — Anthropic Claude (Primary) ─────────────────────────────────────────
# Used for TUSS code suggestion and glosa risk scoring.
# Required when FEATURE_AI_TUSS=True.
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI — OpenAI (Whisper + fallback) ─────────────────────────────────────────
# Used for audio transcription (Whisper) when the browser Web Speech API fails
# or the user uses an unsupported browser. Required when FEATURE_AI_SCRIBE=True.
OPENAI_API_KEY=sk-...

# ─── AI — Feature Flags ───────────────────────────────────────────────────────
# Clinical AI Scribe (Sprint 15). Generates SOAP notes from consultation
# audio. Tenant admin must also sign the DPA via the UI before use.
# Requires a valid OPENAI_API_KEY. Leave False until both are configured.
FEATURE_AI_SCRIBE=False

# TUSS code suggestion via LLM. Requires a valid ANTHROPIC_API_KEY.
FEATURE_AI_TUSS=False

# Whisper (server-side) fallback when browser Web Speech API is unavailable.
# Independent of FEATURE_AI_SCRIBE on/off — when scribe is on, this controls
# whether unsupported browsers get Whisper transcription instead of a hard fail.
FEATURE_WHISPER_FALLBACK=True

# ─── PIX — Asaas Payment Gateway (S-055) ─────────────────────────────────────
# Create sandbox account at: https://sandbox.asaas.com
# Sandbox keys start with $aact_, production keys with $act_
ASAAS_API_KEY=$aact_...
ASAAS_WEBHOOK_TOKEN=change-me-to-random-32-char-string
ASAAS_ENVIRONMENT=sandbox
PIX_CHARGE_EXPIRY_MINUTES=30

# ─── WhatsApp — Evolution API ─────────────────────────────────────────────────
WHATSAPP_EVOLUTION_URL=http://localhost:8080
WHATSAPP_EVOLUTION_API_KEY=change-me
WHATSAPP_WEBHOOK_SECRET=change-me-to-random-32-char-string
WHATSAPP_INSTANCE_NAME=vitali
WHATSAPP_CLINIC_PHONE=+5511999999999

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxx
DEFAULT_FROM_EMAIL=noreply@vitali.com.br

# ─── Sentry (Production) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── MFA — TOTP (S-062) ──────────────────────────────────────────────────────
# Days a verified MFA session stays valid before re-challenge (default: 30)
MFA_GRACE_PERIOD_DAYS=30

# ─── Prescription PDF (S-065) ────────────────────────────────────────────────
# Redis TTL in seconds for generated prescription PDFs (default: 3600 = 1h)
PRESCRIPTION_PDF_CACHE_TTL=3600

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
