# ─── HealthOS Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in the values before running.
# NEVER commit .env to version control.

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=healthos.settings.development
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.healthos.local

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://healthos:healthos@localhost:5435/healthos

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Encryption (LGPD — CPF e dados sensíveis) ───────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=UXVhbHF1ZXIgY2hhdmUgcGFyYSBkZXNlbnZvbHZpbWVudG8=

# ─── AI — Anthropic Claude (Primary) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI — OpenAI (Fallback) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── WhatsApp — Evolution API ─────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.xxx
DEFAULT_FROM_EMAIL=noreply@healthos.com.br

# ─── Sentry (Production) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
